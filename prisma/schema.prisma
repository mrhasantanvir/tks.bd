generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// User Management with OTP & Roles
model users {
  id            Int         @id @default(autoincrement())
  mobile_number String      @unique @db.VarChar(15)
  full_name     String?     @db.VarChar(100)
  email         String?     @db.VarChar(100)
  role          users_role? @default(customer)
  otp_code      String?     @db.VarChar(6)
  otp_expiry    DateTime?   @db.DateTime(0)
  is_verified   Boolean?    @default(false)
  created_at    DateTime    @default(now()) @db.Timestamp(0)
  
  addresses     addresses[]
  orders        orders[]
  reviews       reviews[]
  sms_logs      sms_logs[]
}

enum users_role {
  customer
  admin
  staff
}

// Multi-Address & Gift System (Updated for Districts & Upazilas)
model addresses {
  id              Int        @id @default(autoincrement())
  user_id         Int?
  receiver_name   String?    @db.VarChar(100)
  receiver_mobile String?    @db.VarChar(15)
  district_id     Int?
  upazila_id      Int?
  address_details String?    @db.Text
  is_default      Boolean?   @default(false)
  
  users           users?     @relation(fields: [user_id], references: [id])
  districts       districts? @relation(fields: [district_id], references: [id])
  upazilas        upazilas?  @relation(fields: [upazila_id], references: [id])
  orders          orders[]

  @@index([district_id])
  @@index([user_id])
  @@index([upazila_id])
}

// Shipping Matrix (Dhaka/Outside)
model districts {
  id                  Int         @id @default(autoincrement())
  name                String      @db.VarChar(50) @unique
  is_dhaka            Boolean?    @default(false)
  home_delivery_rate  Decimal?    @db.Decimal(10, 2) @default(120.00)
  point_delivery_rate Decimal?    @db.Decimal(10, 2) @default(60.00)
  
  addresses           addresses[]
  upazilas            upazilas[]
}

// Upazilas / Thanas
model upazilas {
  id          Int       @id @default(autoincrement())
  district_id Int
  name        String    @db.VarChar(100)
  
  districts   districts @relation(fields: [district_id], references: [id])
  addresses   addresses[]

  @@index([district_id])
}

// Product Management
model products {
  id                   Int                @id @default(autoincrement())
  name                 String             @db.VarChar(100)
  short_description    String?            @db.Text
  detailed_description String?            @db.Text
  price_per_unit       Decimal?           @db.Decimal(10, 2)
  unit_type_old        String?            @db.VarChar(20) // Temporary for migration if needed
  lot_size             Int?               @default(1)
  available_stock      Decimal?           @db.Decimal(10, 2)
  preorder_booked      Decimal?           @default(0.00) @db.Decimal(10, 2)
  
  // Delivery & Logistics
  allow_home_delivery  Boolean            @default(true)
  allow_point_delivery Boolean            @default(true)
  available_couriers   String?            @db.Text // JSON list of courier IDs/Names
  
  // Payment Policies
  payment_policy       products_payment_policy @default(cod)
  partial_advance_val  Decimal?           @db.Decimal(10, 2) // Fixed amount or percentage

  harvest_date         DateTime?          @db.Date
  image_url            String?            @db.Text
  category_id          Int?
  unit_id              Int?
  packaging_charge     Decimal?           @db.Decimal(10, 2) @default(0.00)
  is_preorder          Boolean?           @default(false)
  created_at           DateTime           @default(now()) @db.Timestamp(0)
  
  categories           categories?        @relation(fields: [category_id], references: [id])
  units                units?             @relation(fields: [unit_id], references: [id])
  order_items          order_items[]
  product_gallery      product_gallery[]
  reviews              reviews[]

  @@index([category_id])
  @@index([unit_id])
}

model categories {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(100)
  slug       String     @unique @db.VarChar(100)
  products         products[]
  lots             lots[]
  shipping_configs shipping_configs[]
}

model units {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(50) @unique // e.g. kg, piece, liter
  products   products[]
}

model lots {
  id               Int        @id @default(autoincrement())
  category_id      Int
  name             String     @db.VarChar(100) // e.g. "12kg Premium Box"
  size             Decimal    @db.Decimal(10, 2)
  packaging_charge Decimal    @db.Decimal(10, 2)
  
  categories       categories @relation(fields: [category_id], references: [id])
}



enum products_payment_policy {
  cod
  partial_advance
  full_advance
}

model product_gallery {
  id         Int       @id @default(autoincrement())
  product_id Int?
  image_url  String?   @db.Text
  created_at DateTime  @default(now()) @db.Timestamp(0)
  
  products   products? @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
}

// Order & Split-Shipping System
model orders {
  id                  Int                    @id @default(autoincrement())
  user_id             Int?
  address_id          Int?
  total_product_price Decimal?               @db.Decimal(10, 2)
  total_shipping_cost Decimal?               @db.Decimal(10, 2)
  grand_total         Decimal?               @db.Decimal(10, 2)
  order_status        orders_order_status?   @default(pending)
  payment_status      orders_payment_status? @default(unpaid)
  payment_method      String?                @db.VarChar(50)
  is_gift             Boolean?               @default(false)
  created_at          DateTime               @default(now()) @db.Timestamp(0)
  
  order_items         order_items[]
  order_packages      order_packages[]
  payments            payments[]
  users               users?                 @relation(fields: [user_id], references: [id])
  addresses           addresses?             @relation(fields: [address_id], references: [id])

  @@index([address_id])
  @@index([user_id])
}

model order_items {
  id           Int       @id @default(autoincrement())
  order_id     Int?
  product_id   Int?
  quantity     Int?
  unit_weight  Decimal?  @db.Decimal(10, 2)
  price        Decimal?  @db.Decimal(10, 2)
  harvest_date DateTime? @db.Date
  
  orders       orders?   @relation(fields: [order_id], references: [id])
  products     products? @relation(fields: [product_id], references: [id])

  @@index([order_id])
  @@index([product_id])
}

model order_packages {
  id                     Int                            @id @default(autoincrement())
  order_id               Int?
  courier_name           String?                        @db.VarChar(100) // Steadfast/Sundarban
  tracking_number        String?                        @db.VarChar(100)
  package_status         order_packages_package_status? @default(waiting_for_harvest)
  expected_shipping_date DateTime?                      @db.Date
  weight                 Decimal?                       @db.Decimal(10, 2)
  shipping_cost          Decimal?                       @db.Decimal(10, 2)
  
  orders                 orders?                        @relation(fields: [order_id], references: [id])

  @@index([order_id])
}

// Payment Tracking
model payments {
  id             Int             @id @default(autoincrement())
  order_id       Int?
  transaction_id String?         @unique @db.VarChar(100)
  payment_method String?         @db.VarChar(50) // bKash, Nagad
  amount         Decimal?        @db.Decimal(10, 2)
  status         payments_status @default(pending)
  created_at     DateTime        @default(now()) @db.Timestamp(0)
  
  orders         orders?         @relation(fields: [order_id], references: [id])

  @@index([order_id])
}

// Customer Reviews
model reviews {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  product_id Int?
  user_name  String?   @db.VarChar(100) // For manually added reviews
  rating     Int       @default(5)
  comment    String?   @db.Text
  image_url  String?   @db.Text        // For manually added profile pictures
  is_visible Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamp(0)
  
  users      users?    @relation(fields: [user_id], references: [id])
  products   products? @relation(fields: [product_id], references: [id])

  @@index([user_id])
  @@index([product_id])
}

// SMS & Notification Logs
model sms_logs {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  mobile     String   @db.VarChar(15)
  message    String   @db.Text
  status     String?  @db.VarChar(20) // sent, failed
  created_at DateTime @default(now()) @db.Timestamp(0)
  
  users      users?   @relation(fields: [user_id], references: [id])

  @@index([user_id])
}

// Global Site Settings
model settings {
  id           Int     @id @default(autoincrement())
  key          String  @unique @db.VarChar(100)
  value        String? @db.Text
  description  String? @db.VarChar(255)
}

// Enums
enum order_packages_package_status {
  waiting_for_harvest
  processing
  shipped
  delivered
  cancelled
}

enum orders_order_status {
  pending
  confirmed
  partially_shipped
  delivered
  cancelled
}

enum orders_payment_status {
  unpaid
  partial
  paid
  refunded
}

enum payments_status {
  pending
  completed
  failed
  refunded
}

model site_announcements {
  id         Int      @id @default(autoincrement())
  message    String   @db.Text
  link       String?  @db.VarChar(255)
  type       String   @default("info")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
}

model shipping_configs {
  id                   Int        @id @default(autoincrement())
  courier_name         String     @db.VarChar(100)
  category_id          Int?
  is_weight_based      Boolean    @default(false)
  dhaka_office_rate    Decimal    @db.Decimal(10, 2)
  outside_office_rate  Decimal    @db.Decimal(10, 2)
  dhaka_home_rate      Decimal    @db.Decimal(10, 2)
  outside_home_rate    Decimal    @db.Decimal(10, 2)

  categories           categories? @relation(fields: [category_id], references: [id])
  @@index([category_id])
}
